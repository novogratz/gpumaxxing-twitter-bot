# ──────────── Identity ────────────
BOT_HANDLE=gpumaxxing

# ──────────── AI provider ────────────
# ollama / codex / opencode / claude / gemini. Default uses local Ollama;
# Codex is the recommended cloud backup.
AI_CLI=ollama
LLM_FALLBACK_CLI=codex
NEWS_MODEL=opencode/big-pickle
HOTAKE_MODEL=opencode/big-pickle
REPLY_MODEL=opencode/big-pickle
PRIORITY_REPLY_MODEL=opencode/big-pickle
QUOTE_MODEL=opencode/big-pickle
ROAST_MODEL=opencode/big-pickle

# ──────────── Daily caps — original content ────────────
MAX_NEWS_PER_DAY=10
MAX_HOTAKES_PER_DAY=0
MAX_BREAKOUTS_PER_DAY=4
MAX_SPICY_PER_DAY=4

# ──────────── Daily caps — reshare + engagement ────────────
MAX_QUOTES_PER_DAY=80
MAX_RETWEETS_PER_DAY=30
MAX_REPLIES_PER_CYCLE=8
DIRECT_REPLY_MAX_PER_CYCLE=32
DIRECT_REPLY_MAX_EN_PER_CYCLE=5
MAX_SELECTIVE_FOLLOWS=400

# ──────────── Per-cycle quotas ────────────
RETWEETS_PER_CYCLE=3
FOLLOW_BLAST_PER_CYCLE=5
FOLLOW_BLAST_DAILY_CAP=40
LIKE_BOT_PER_CYCLE=22
LIKE_BOT_DAILY_CAP=1800
RETWEET_MIN_LIKES=25
RETWEET_MAX_AGE_HOURS=18
FEED_REPOST_MIN_ENGAGEMENT=5
FAVORITE_REPOSTS_PER_CYCLE=3
FAVORITE_REPOST_MIN_ENGAGEMENT=3
FAVORITE_REPOST_MAX_AGE_MINUTES=2880
RETWEET_FEED_SEARCHES_PER_CYCLE=5
DIRECT_REPLY_MAX_AGE_MINUTES=1440
X_FEED_SEARCHES_PER_CYCLE=2
LIKE_TOP_TAB_PROBABILITY=0.55
QUOTE_MAX_AGE_HOURS=18

# ──────────── Rate limits ────────────
LLM_MIN_SECONDS_BETWEEN_CALLS=75
LLM_MAX_CALLS_PER_HOUR=32
NEWS_POSTS_PER_CYCLE=3
NEWS_POST_SPACING_SECONDS=120

# ──────────── Self-modification toggles ────────────
ENABLE_AI_MAINTENANCE=0
ENABLE_AI_DISCOVERY=0

# ──────────── Language ────────────
# en / fr / mixed. Replies always match parent tweet language regardless.
CONTENT_LANG_PRIMARY=en

# Twitter API tokens NOT REQUIRED — the bot uses browser automation only.
